{return(0.57721)}
]]]

?func.Fahrenheit(var_local|n|;) [[[
{return((var_local|n|*9/5)+32)}
]]]

?func.Celsius(var_local|n|;) [[[
{return((var_local|n|-32)/9*5)}
]]]

?func.rad(var_local|n|;) [[[
