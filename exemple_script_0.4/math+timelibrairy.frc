{var_local|r|=var_local|n|#1}
{if?||sign(var_local|n|)||{return(var_local|r|+1)}}
{return(var_local|r|)}
]]]

?func.pgcd(var_local|a|;var_local|b|;)[[[
{if!||is_compatible()||{return(-1)}}
{repeat||infini||
    {if||var_local|b|||?=||0||{break}}
    {var_local|temp|=var_local|b|}
    {var_local|b|=var_local|a|%var_local|b|}
    {var_local|a|=var_local|temp|}
}
{return(var_local|a|)}
]]]

?func.ppcm(var_local|a|;var_local|b|;) [[[
{if!||is_compatible()||{return(-1)}}
{var_local|p|=2}
{table_local|r|=[[]]}
{repeat||infini||
	{if(||var_local|a|||<=||1|| and ||var_local|b|||<=||1||){break}}
	{var_local|bool1|=0}
	{if||(var_local|a|#var_local|p|)||!=||(var_local|a|/var_local|p|)||{var_local|bool1|=1}}
	{var_local|bool2|=0}
	{if||(var_local|b|#var_local|p|)||!=||(var_local|b|/var_local|p|)||{var_local|bool2|=1}}
	{if(?||var_local|bool1||| and ?||var_local|bool2|||)
		{repeat||infini||
			{var_local|p|=++}
			{if?||is_prime(var_local|p|)||{break}}
		}
		{continue}
	}
	{table_local|r|.add(var_local|p|)}
	{if!||var_local|bool1|||
		{var_local|a|=var_local|a|/var_local|p|}
	}
	{if!||var_local|bool2|||
		{var_local|b|=var_local|b|/var_local|p|}
	}
}
{var_local|r|=1}
{var_local|i|=1}
{repeat||table_local|r|.len()||
	{var_local|r|=var_local|r|*table_local|r|[var_local|i|]}
	{var_local|i|=++}
}
{return(var_local|r|)}
]]]

?func.is_prime(var_local|n|;)[[[
{if!||is_compatible()||{return(-1)}}
{if||var_local|n|||<||1||{return(-1)}}
{if||var_local|n|||<=||2||{return(1)}}
{if||var_local|n|%2||?=||0||{return(0)}}
{var_local|i|=3}
{repeat||infini||
    {if||var_local|i|*var_local|i|||>||var_local|n|||{break}}
    {if||var_local|n|%var_local|i|||?=||0||{return(0)}}
    {var_local|i|=var_local|i|+2}
}
{return(1)}
]]]
